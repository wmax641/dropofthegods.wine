    "ingredients": [
      { "amount": 45,   "unit": "mL", "ingredient": "whisky" },
      { "amount": 90,   "unit": "mL", "ingredient": "soda water" }
    ],
    "method": [
      "add whisky and half ice, stir",
      "add the rest of the ice",
      "add soda, avoid pouring on the ice",
      "using barspoon, smoothly lift ice a few times to mix",
